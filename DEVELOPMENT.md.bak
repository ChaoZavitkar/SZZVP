## 📊 Cypher dotazy - které budeme potřebovat

```cypher
# Registrace - vytvoření uživatele
CREATE (user:User {
  id: $id,
  email: $email,
  password_hash: $password_hash,
  created_at: datetime()
})

# Login - ověření uživatele
MATCH (user:User)
WHERE user.email = $email
RETURN user

# Vytvoření profilu
CREATE (profile:UserProfile {
  user_id: $user_id,
  nickname: $nickname,
  bio: $bio,
  nerd_level: $nerd_level,
  created_at: datetime()
})

# Propojení profilu s uživatelem
MATCH (user:User {id: $user_id})
MATCH (profile:UserProfile {user_id: $user_id})
CREATE (user)-[:HAS_PROFILE]->(profile)

# Přidání zájmů
MATCH (profile:UserProfile {user_id: $user_id})
MATCH (interest:Interest {name: $interest_name})
CREATE (profile)-[:INTERESTED_IN]->(interest)

# Vyhledávání profilů (bez filtrů)
MATCH (other:User)-[:HAS_PROFILE]->(profile:UserProfile)
WHERE other.id <> $current_user_id
AND other.is_deleted <> true
RETURN profile, other
LIMIT 10

# Vyhledávání s filtrováním
MATCH (other:User)-[:HAS_PROFILE]->(profile:UserProfile)
WHERE other.id <> $current_user_id
AND profile.nerd_level >= $min_nerd
AND profile.nerd_level <= $max_nerd
AND (profile)-[:INTERESTED_IN]->(i:Interest)
AND i.name IN $interests
RETURN profile, other
LIMIT 10

# Vytvoření like
MATCH (sender:User {id: $sender_id})
MATCH (receiver:User {id: $receiver_id})
CREATE (conn:Connection {
  id: $id,
  sender_id: $sender_id,
  receiver_id: $receiver_id,
  is_match: false,
  created_at: datetime()
})

# Kontrola na match (oboustranný like)
MATCH (c1:Connection)
WHERE c1.sender_id = $user_a
AND c1.receiver_id = $user_b
MATCH (c2:Connection)
WHERE c2.sender_id = $user_b
AND c2.receiver_id = $user_a
RETURN true

# Načtení matchů
MATCH (conn:Connection)
WHERE (conn.sender_id = $user_id OR conn.receiver_id = $user_id)
AND conn.is_match = true
RETURN conn
```

